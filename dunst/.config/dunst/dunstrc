# Restart dunst
#   killall dunst; dunst &
#
# Test dunst config changes
#   notify-send "Testing" "Test notification"

[global]
    follow = mouse
    font = Adwaita Mono 13

    # Set the launcher app for notification actions and context menus
    dmenu = rofi -dmenu -p "Notification Actions"

    # Set mouse events to invoke the action / context menu
    mouse_left_click = close_current
    mouse_middle_click = context
    mouse_right_click = context

[shortcuts]
    # Open the context menu (shows URLs and intent actions)
    context = mod4+shift+period
